        {
          "expr": "max by (pod) (kube_pod_status_ready{namespace=\"$namespace\", condition=\"true\", pod=~\"$pod.*\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Pod Status",
      "type": "state-timeline"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
